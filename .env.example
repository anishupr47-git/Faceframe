# Frontend API config
# Local dev default in code: http://127.0.0.1:8000/recommend
VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_RECOMMEND_PATH=/recommend

# In production you usually want real API only.
# true  -> fallback to local mock recommendations if API fails
# false -> show API failure in UI instead of mock
VITE_ENABLE_MOCK_FALLBACK=false
